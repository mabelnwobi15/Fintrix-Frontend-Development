@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Fintrix Login</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            font-family: 'Raleway', sans-serif;
            background: linear-gradient(135deg, #05070f, #0a0f2c, #000000);
            color: #fff;
            overflow: hidden;
        }

        .container-fluid {
            height: 100vh;
        }

        /* LEFT SIDE */
        .left-side {
            background: url('https://images.unsplash.com/photo-1640161704729-cbe966a08476') no-repeat center;
            background-size: cover;
            position: relative;
        }

        .overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom right, rgba(0,0,0,0.8), rgba(10,15,44,0.9));
        }

        .branding {
            position: absolute;
            bottom: 60px;
            left: 60px;
            color: #fff;
        }

            .branding img {
                width: 160px;
            }

            .branding h2 {
                font-weight: 700;
                margin-top: 15px;
            }

            .branding p {
                opacity: 0.7;
            }

        /* RIGHT SIDE */
        .right-side {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* GLASS CARD */
        .login-box {
            width: 100%;
            max-width: 420px;
            padding: 40px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        }

            .login-box img {
                width: 120px;
            }

        .subtitle {
            color: #aaa;
            margin-bottom: 25px;
        }

        /* INPUTS */
        .form-group {
            position: relative;
            margin-bottom: 20px;
        }

        .form-control {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            height: 50px;
            color: #fff;
        }

            .form-control:focus {
                border-color: #4e73ff;
                box-shadow: 0 0 10px rgba(78,115,255,0.5);
                background: transparent;
                color: #fff;
            }

            .form-control::placeholder {
                color: #aaa;
            }

        /* PASSWORD ICON */
        .toggle-password {
            position: absolute;
            right: 15px;
            top: 13px;
            cursor: pointer;
            color: #aaa;
        }

            .toggle-password:hover {
                color: #fff;
            }

        /* OPTIONS */
        .options {
            font-size: 14px;
        }

            .options a {
                color: #4e73ff;
                text-decoration: none;
            }

                .options a:hover {
                    text-decoration: underline;
                }

        /* BUTTON */
        .btn-primary {
            height: 50px;
            border-radius: 12px;
            font-weight: 600;
            border: none;
            background: linear-gradient(135deg, #1a2cff, #4e73ff);
            transition: 0.3s;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(78,115,255,0.5);
            }

        /* SIGNUP LINK */
        .signup {
            font-size: 14px;
            color: #aaa;
            margin-top: 15px;
        }

            .signup a {
                color: #4e73ff;
                font-weight: 600;
                margin-left: 5px;
                text-decoration: none;
                transition: 0.3s;
            }

                .signup a:hover {
                    color: #ffffff;
                    text-shadow: 0 0 8px rgba(78,115,255,0.8);
                }

        /* FOOTER */
        .footer {
            font-size: 12px;
            color: #777;
            margin-top: 20px;
            text-align: center;
        }

        /* MOBILE */
        
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="row h-100">

            <!-- LEFT SIDE -->
            <div class="col-md-6 left-side">
                <div class="overlay"></div>

                <div class="branding">
                    <img src="/image/logo.png" />
                    <h2>Fintrix</h2>
                    <p style="color: yellow;">Where finance meets intelligence</p>
                </div>
            </div>

            <!-- RIGHT SIDE -->
            <div class="col-md-6 right-side">
                <div class="login-box text-center">

                    <img src="/image/logo.png" class="mb-3" />

                    <h4 class="mb-2" style="color: yellow;">Welcome Back</h4>
                    <div class="subtitle">Sign in to continue</div>

                    <form method="post" onsubmit="showLoading()">

                        <!-- EMAIL -->
                        <div class="form-group">
                            <input type="email" name="email" class="form-control" placeholder="Email address" required />
                        </div>

                        <!-- PASSWORD -->
                        <div class="form-group">
                            <input type="password" id="password" name="password" class="form-control" placeholder="Password" required />
                            <i class="bi bi-eye toggle-password" onclick="togglePassword()"></i>
                        </div>

                        <!-- OPTIONS -->
                        <div class="d-flex justify-content-between options mb-3">
                            <div>
                                 
                             
                            </div>
                              
                        </div>

                        <!-- BUTTON -->
                        <button type="submit" id="loginBtn" class="btn btn-primary w-100">
                            Login
                        </button>

                        <!-- SIGN UP -->
                        <div class="signup">
                            <span>Don’t have an account?</span>
                            <a href="/Account/Register">Create one</a>
                        </div>

                    </form>

                    <!-- ERROR -->
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3">
                            @ViewBag.Error
                        </div>
                    }

                    <div class="footer">
                        © 2026 Fintrix. All rights reserved.
                    </div>

                </div>
            </div>

        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById("password");
            input.type = input.type === "password" ? "text" : "password";
        }

        function showLoading() {
            const btn = document.getElementById("loginBtn");
            btn.innerHTML = "Signing in...";
            btn.disabled = true;
        }
    </script>

</body>
</html>