@model List<SmartInvoice.MVC.Models.InvoiceViewModel>

@{
    ViewData["Title"] = "Invoices";
    var total = Model.Count;
    var paid = Model.Count(i => i.Status == "Paid");
    var pending = Model.Count(i => i.Status == "Pending");
    var overdue = Model.Count(i => i.Status == "Overdue");
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<style>
    .card-box {
        border-radius: 15px;
        padding: 20px;
        background: #f8f9fa;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .status-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
    }

    .paid {
        background: #d4edda;
        color: #155724;
    }

    .pending {
        background: #fff3cd;
        color: #856404;
    }

    .overdue {
        background: #f8d7da;
        color: #721c24;
    }

    .header-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .action-container {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    /* Base button */
    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        transition: all 0.25s ease;
        cursor: pointer;
        text-decoration: none;
    }

    /* View Button */
    .view-btn {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
    }

        .view-btn:hover {
            background: #2563eb;
            color: #fff;
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
        }

    /* Download Button */
    .download-btn {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

        .download-btn:hover {
            background: #10b981;
            color: #fff;
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
        }

    /* Smooth icon animation */
    .action-btn i {
        transition: transform 0.2s ease;
    }

    .action-btn:hover i {
        transform: scale(1.2);
    }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="header-box mb-4">
        <div>
            <h2>Invoices</h2>
            <p class="text-muted">Create and manage invoices</p>
        </div>

        <a href="/Invoice/Create" class="btn btn-primary">
            + Create Invoice
        </a>
    </div>

    <!-- SEARCH -->
    <div class="card-box mb-4">
        <input type="text" id="invoiceSearch" class="form-control" placeholder="Search invoices..." />
        <div class="mt-3">
            <button class="btn btn-primary btn-sm" onclick="filterStatus('')">All</button>
            <button class="btn btn-light btn-sm" onclick="filterStatus('Paid')">Paid</button>
            <button class="btn btn-light btn-sm" onclick="filterStatus('Pending')">Pending</button>
            <button class="btn btn-light btn-sm" onclick="filterStatus('Overdue')">Overdue</button>
        </div>
    </div>

    <!-- STATS -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card-box">
                <p>Total Invoices</p>
                <h3>@total</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-box">
                <p>Paid</p>
                <h3 class="text-success">@paid</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-box">
                <p>Pending</p>
                <h3 class="text-warning">@pending</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-box">
                <p>Overdue</p>
                <h3 class="text-danger">@overdue</h3>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card-box">
        <table class="table align-middle" id="invoiceTable">
            <thead>
                <tr>
                    <th>Invoice</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Due Date</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var invoice in Model)
                {
                    <tr data-status="@invoice.Status">
                        <td><strong>INV-@invoice.Id.ToString("D5")</strong></td>
                        <td>@invoice.ClientName</td>
                        <td>@invoice.Date.ToString("MMM dd, yyyy")</td>
                        <td>@invoice.DueDate.ToString("MMM dd, yyyy")</td>
                        <td><strong>R @invoice.TotalAmount.ToString("N2")</strong></td>
                        <td>
                            <span class="status-badge
                                      @(invoice.Status == "Paid" ? "paid" :
                                                                      invoice.Status == "Pending" ? "pending" : "overdue")">
                                @invoice.Status
                            </span>
                        </td>
                        <td>
                            <div class="action-container">
                                <!-- View -->
                                <button class="action-btn view-btn"
                                        onclick="openInvoiceModal(@invoice.Id)"
                                        title="View Invoice">
                                    <i class="bi bi-eye-fill"></i>
                                </button>

                                <!-- Email -->
                                <a href="https://mail.google.com/mail/?view=cm&fs=1&to=example@gmail.com&su=Hello&body=Your message here"
                                   class="action-btn download-btn"
                                   title="Send email"
                                   target="_blank">
                                    <i class="bi bi-envelope"></i>
                                </a>


                            </div>

                           


                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Invoice Modal -->
        <div class="modal fade" id="invoiceModal">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Invoice Preview</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body" id="invoiceModalContent">
                        Loading invoice...
                    </div>

                </div>
            </div>
        </div>

        <script>
            function openInvoiceModal(id) {
                fetch('/Invoice/Details/' + id)
                    .then(res => res.text())
                    .then(html => {
                        document.getElementById("invoiceModalContent").innerHTML = html;
                        var modal = new bootstrap.Modal(document.getElementById("invoiceModal"));
                        modal.show();
                    });
            }

            const searchInput = document.getElementById('invoiceSearch');
            let currentStatus = '';

            function filterInvoices() {
                const filter = searchInput.value.toLowerCase();
                const rows = document.querySelectorAll('#invoiceTable tbody tr');

                rows.forEach(row => {
                    const textMatch = row.innerText.toLowerCase().includes(filter);
                    const statusMatch = !currentStatus || row.getAttribute('data-status') === currentStatus;
                    row.style.display = textMatch && statusMatch ? '' : 'none';
                });
            }

            function filterStatus(status) {
                currentStatus = status;
                filterInvoices();
            }

            searchInput.addEventListener('keyup', filterInvoices);
        </script>

    </div>
</div>